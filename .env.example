# ── Required ──
ANTHROPIC_API_KEY=sk-ant-...        # AI Research Agent (server-side only)

# ── Email delivery (newsletter + contact → your inbox) ──
SMTP_USER=you@gmail.com             # Gmail address
SMTP_PASS=xxxx xxxx xxxx xxxx       # Gmail App Password (Google Account → Security → App passwords)
NOTIFY_EMAIL=you@gmail.com          # where submissions land (defaults to SMTP_USER)

# ── Optional ──
ALLOWED_ORIGINS=https://taxclarity.onrender.com   # lock CORS to your domain
ENABLE_WEB_SEARCH=false             # true = agent verifies via live web search (adds time + cost)
AGENT_MODEL=claude-sonnet-4-6
DEBUG=false
